{"$schema":"https://json-schema.org/draft/2020-12/schema","title":"Bootstrap Review Metadata","type":"object","additionalProperties":false,"required":["Review-Record-ID","Workspace-ID","Manifest-Ref","Manifest-SHA256","Reviewer","Decision-Owner","Result","Reviewed-At","Valid-Until"],"properties":{"Review-Record-ID":{"type":"string","minLength":1},"Workspace-ID":{"type":"string","minLength":1},"Manifest-Ref":{"const":"BOOTSTRAP-MANIFEST.json"},"Manifest-SHA256":{"type":"string","pattern":"^[a-f0-9]{64}$"},"Reviewer":{"type":"string","minLength":1},"Decision-Owner":{"type":"string","minLength":1},"Result":{"enum":["READY","BLOCKED"]},"Reviewed-At":{"type":"string","minLength":1},"Valid-Until":{"type":"string","minLength":1},"extensions":{"type":"object","additionalProperties":true}}}
