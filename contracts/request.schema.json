{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boring-admin-ai-rail/public-operational/request.schema.json",
  "title": "Public Operational Request Contract",
  "description": "Documentation-only request data contract. It does not authorize or execute work.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "request_id",
    "intent_id",
    "actor_type",
    "role",
    "scope",
    "bootstrap_state",
    "selected_modules",
    "decision_owner_ref",
    "execution_capability"
  ],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "intent_id": { "type": "string", "minLength": 1 },
    "actor_type": { "type": "string", "enum": ["human", "ai"] },
    "role": {
      "type": "string",
      "enum": ["System Architect", "Architect-AI", "Senior Developer", "Reviewer / Auditor"]
    },
    "scope": {
      "type": "object",
      "required": ["target", "kind", "boundary"],
      "properties": {
        "target": { "type": "string", "enum": ["host-project"] },
        "kind": { "type": "string", "enum": ["bootstrap", "delivery", "review"] },
        "boundary": { "type": "string", "minLength": 1 }
      }
    },
    "bootstrap_state": { "type": "string", "enum": ["UNPACKED", "SEEDED", "MAPPED", "READY"] },
    "selected_modules": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["development", "devops", "infrastructure", "security", "data"] }
    },
    "change_surfaces": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "decision_owner_ref": { "type": "string", "minLength": 1 },
    "authorization_ref": { "type": "string", "minLength": 1 },
    "authority_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["adopted_contract", "decision_record"] }
        }
      }
    },
    "execution_capability": { "const": false }
  },
  "allOf": [
    {
      "if": { "properties": { "scope": { "properties": { "kind": { "const": "delivery" } }, "required": ["kind"] } }, "required": ["scope"] },
      "then": { "required": ["change_surfaces", "authorization_ref"], "properties": { "bootstrap_state": { "const": "READY" }, "selected_modules": { "minItems": 1 }, "change_surfaces": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "actor_type": { "const": "ai" } }, "required": ["actor_type"] },
      "then": { "properties": { "role": { "not": { "const": "System Architect" } } } }
    }
  ]
}
