{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boring-admin-ai-rail/public-operational/evidence.schema.json",
  "title": "Public Operational Evidence Contract",
  "description": "Portable evidence data shape. Chain validation is intentionally deferred to a later executable profile.",
  "type": "object",
  "additionalProperties": true,
  "required": ["manifest_id", "intent_id", "bootstrap_state", "selected_modules", "records"],
  "properties": {
    "manifest_id": { "type": "string", "minLength": 1 },
    "intent_id": { "type": "string", "minLength": 1 },
    "bootstrap_state": { "type": "string", "enum": ["UNPACKED", "SEEDED", "MAPPED", "READY"] },
    "selected_modules": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["record_id", "record_type", "role", "status", "artifact_path", "artifact_sha256", "previous_record_id"],
        "properties": {
          "record_id": { "type": "string", "minLength": 1 },
          "record_type": { "type": "string", "enum": ["intent", "architect_review", "authorization", "delivery", "review_result", "bootstrap_review", "closure"] },
          "role": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "artifact_path": { "type": "string", "minLength": 1 },
          "artifact_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "previous_record_id": { "type": ["string", "null"] }
        }
      }
    }
  }
}
